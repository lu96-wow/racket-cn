#lang racket/base
(require racket/linklet)
(require "../rename-macro.rkt")

(rename-define
  [linklet? 链接件?]
  [compile-linklet 编译链接件]
  [recompile-linklet 重新编译链接件]
  [eval-linklet 求值链接件]
  [instantiate-linklet 实例化链接件]
  [linklet-import-variables 链接件-导入-变量]
  [linklet-export-variables 链接件-导出-变量]
  [linklet-add-target-machine-info 链接件-添加-目标机器信息]
  [linklet-summarize-target-machine-info 链接件-摘要-目标机器信息]
  [decompile-linklet 反编译链接件]
  [linklet-directory? 链接件-目录?]
  [hash->linklet-directory 哈希->链接件-目录]
  [linklet-directory->hash 链接件-目录->哈希]
  [linklet-bundle? 链接件-捆绑?]
  [hash->linklet-bundle 哈希->链接件-捆绑]
  [linklet-bundle->hash 链接件-捆绑->哈希]
  [linklet-body-reserved-symbol? 链接件-体-保留符号?]
  [instance? 实例?]
  [make-instance 制造实例]
  [instance-name 实例-名称]
  [instance-data 实例-数据]
  [instance-variable-names 实例-变量-名称]
  [instance-variable-value 实例-变量-值]
  [instance-set-variable-value! 实例-设置-变量-值!]
  [instance-unset-variable! 实例-取消-变量!]
  [variable-reference->instance 变量引用->实例]
  [correlated? 关联?]
  [datum->correlated 数据->关联]
  [correlated->datum 关联->数据]
  [correlated-e 关联-值]
  [correlated-property 关联-属性]
  [correlated-property-symbol-keys 关联-属性-符号键]
  [correlated-source 关联-源]
  [correlated-line 关联-行]
  [correlated-column 关联-列]
  [correlated-position 关联-位置]
  [correlated-span 关联-跨度]
)
