#lang racket/base
(require racket/set)
(require "../rename-macro.rkt")

(rename-define
  [set 集合]
  [seteq 等同集合]
  [seteqv 等价集合]
  [setalw 全等集合]
  [set? 集合?]
  [set-eq? 等同集合?]
  [set-eqv? 等价集合?]
  [set-equal? 等值集合?]
  [set-empty? 集合-空?]
  [set-member? 集合-成员?]
  [set-count 集合-计数]
  [set=? 集合=?]
  [subset? 子集?]
  [proper-subset? 真子集?]
  [set-map 集合-映射]
  [set-for-each 集合-对每个]
  [set-copy 集合-复制]
  [set-copy-clear 集合-复制-清空]
  [set->list 集合->列表]
  [set->stream 集合->流]
  [set-first 集合-首个]
  [set-rest 集合-剩余]
  [set-add 集合-添加]
  [set-remove 集合-移除]
  [set-clear 集合-清空]
  [set-union 集合-并集]
  [set-intersect 集合-交集]
  [set-subtract 集合-差集]
  [set-symmetric-difference 集合-对称差]
  [set-add! 集合-添加!]
  [set-remove! 集合-移除!]
  [set-clear! 集合-清空!]
  [set-union! 集合-并集!]
  [set-intersect! 集合-交集!]
  [set-subtract! 集合-差集!]
  [set-symmetric-difference! 集合-对称差!]
  [in-set 在-集合]
  [list->set 列表->集合]
  [list->seteq 列表->等同集合]
  [list->seteqv 列表->等价集合]
  [list->setalw 列表->全等集合]
  [mutable-set 可变集合]
  [mutable-seteq 可变等同集合]
  [mutable-seteqv 可变等价集合]
  [mutable-setalw 可变全等集合]
  [weak-set 弱集合]
  [weak-seteq 弱等同集合]
  [weak-seteqv 弱等价集合]
  [weak-setalw 弱全等集合]
  [for/set 循环/集合]
  [for/seteq 循环/等同集合]
  [for/seteqv 循环/等价集合]
  [for/setalw 循环/全等集合]
  [for*/set 循环*/集合]
  [for*/seteq 循环*/等同集合]
  [for*/seteqv 循环*/等价集合]
  [for*/setalw 循环*/全等集合]
)
